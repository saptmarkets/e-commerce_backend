# Smart Tree Configuration for SaptMarkets Project
# This file configures how Smart Tree displays the directory structure

# Ignore patterns - files and directories to exclude
ignore = [
    "node_modules",
    ".next",
    ".git",
    "*.log",
    "*.tmp",
    ".DS_Store",
    "Thumbs.db",
    "dist",
    "build",
    "coverage",
    ".env.local",
    ".env.*.local"
]

# Display options
[display]
# Show file sizes
show_size = true

# Show hidden files (starting with .)
show_hidden = false

# Maximum depth to display (-1 for unlimited)
max_depth = 5

# Sort files by name
sort = "name"

# Use icons for files and folders
use_icons = true

# Color scheme
use_colors = true

# Output formats for different use cases
[formats]
# Default format for human viewing
default = "classic"

# Format for AI/LLM consumption (compressed)
ai = "quantum-semantic"

# Format for documentation
docs = "markdown"

# Custom aliases for common commands
[aliases]
# Quick overview of project structure
overview = "st -m classic --max-depth 3"

# Generate markdown documentation
docs = "st -m markdown > PROJECT_STRUCTURE.md"

# AI-friendly output for code analysis
ai = "st -m ai -z"

# Show only source files
src = "st --type js,jsx,ts,tsx,json" 